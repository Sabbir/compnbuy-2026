# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Scraper tuning ────────────────────────────────────────
PAGE_TIMEOUT=30000       # ms before page navigation times out
PAGE_DELAY=2000          # ms pause between consecutive page loads
WAIT_AFTER_LOAD=2500     # ms extra wait for JS to hydrate after load

# ── Cache ─────────────────────────────────────────────────
CACHE_TTL=300            # seconds to keep cached responses (5 min)
CACHE_ENABLED=true

# ── Rate limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW=60000  # ms window (1 minute)
RATE_LIMIT_MAX=30        # max requests per window per IP

# ── API access protection ──────────────────────────────────
# Generate a strong random secret, e.g.:  openssl rand -hex 32
# Must match VITE_API_SECRET in the frontend .env
API_SECRET=c239fb0f05027c9b35d7ac7659dc61683da32b5ad3e4d5f7e96c27550694a3c9

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example for production:  https://compnbuy.com
# Localhost origins are always allowed in development.
ALLOWED_ORIGIN=https://compnbuy.com

# ── Puppeteer ─────────────────────────────────────────────
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium   # override Chrome path
